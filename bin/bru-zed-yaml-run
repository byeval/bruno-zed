#!/usr/bin/env python3
import argparse
import json
import os
import re
import socket
import sys
import time
import urllib.error
import urllib.parse
import urllib.request


REQUEST_EXTENSIONS = (".yml", ".yaml")
TEXT_CONTENT_TYPES = (
    "application/json",
    "application/problem+json",
    "application/xml",
    "application/xhtml+xml",
    "application/javascript",
    "application/x-www-form-urlencoded",
    "text/",
)


class BrunoYamlError(ValueError):
    pass


class NoRedirectHandler(urllib.request.HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):
        return None


class SimpleYamlParser:
    """A small YAML subset parser for Bruno/OpenCollection request files."""

    def __init__(self, text, path="<string>"):
        self.lines = text.splitlines()
        self.path = path

    def parse(self):
        index = self._skip_ignored(0)
        if index >= len(self.lines):
            return {}
        value, index = self._parse_block(index, self._indent(index))
        index = self._skip_ignored(index)
        if index < len(self.lines):
            self._error(index, "unexpected trailing content")
        return value

    def _parse_block(self, index, indent):
        index = self._skip_ignored(index)
        if index >= len(self.lines):
            return None, index

        current_indent = self._indent(index)
        if current_indent < indent:
            return None, index

        content = self.lines[index][current_indent:]
        if content.startswith("-"):
            return self._parse_sequence(index, current_indent)
        return self._parse_mapping(index, current_indent)

    def _parse_mapping(self, index, indent):
        result = {}
        while index < len(self.lines):
            index = self._skip_ignored(index)
            if index >= len(self.lines):
                break

            current_indent = self._indent(index)
            if current_indent < indent:
                break
            if current_indent > indent:
                self._error(index, "unexpected indentation")

            content = self.lines[index][indent:]
            if content.startswith("-"):
                break

            key, value_text = self._split_key_value(content, index)
            key = self._parse_key(key)
            value, index = self._parse_value(value_text, index, indent)
            result[key] = value

        return result, index

    def _parse_sequence(self, index, indent):
        result = []
        while index < len(self.lines):
            index = self._skip_ignored(index)
            if index >= len(self.lines):
                break

            current_indent = self._indent(index)
            if current_indent < indent:
                break
            if current_indent > indent:
                self._error(index, "unexpected indentation")

            content = self.lines[index][indent:]
            if not content.startswith("-"):
                break

            item_text = content[1:]
            if item_text.startswith(" "):
                item_text = item_text[1:]
            elif item_text:
                self._error(index, "expected a space after '-'")

            if not item_text:
                next_index = self._skip_ignored(index + 1)
                if next_index < len(self.lines) and self._indent(next_index) > indent:
                    item, index = self._parse_block(next_index, self._indent(next_index))
                else:
                    item, index = None, index + 1
                result.append(item)
                continue

            if self._looks_like_key_value(item_text):
                key, value_text = self._split_key_value(item_text, index)
                item = {}
                value, index = self._parse_value(value_text, index, indent + 2)
                item[self._parse_key(key)] = value

                next_index = self._skip_ignored(index)
                if next_index < len(self.lines) and self._indent(next_index) > indent:
                    extra, index = self._parse_mapping(next_index, self._indent(next_index))
                    item.update(extra)
                result.append(item)
                continue

            result.append(self._parse_scalar(item_text))
            index += 1

        return result, index

    def _parse_value(self, value_text, index, indent):
        value_text = value_text.strip()

        if not value_text:
            next_index = self._skip_ignored(index + 1)
            if next_index < len(self.lines) and self._indent(next_index) > indent:
                return self._parse_block(next_index, self._indent(next_index))
            return None, index + 1

        if self._is_block_scalar(value_text):
            return self._parse_block_scalar(index + 1, indent, value_text)

        return self._parse_scalar(value_text), index + 1

    def _parse_block_scalar(self, index, parent_indent, indicator):
        raw_lines = []
        while index < len(self.lines):
            line = self.lines[index]
            if line.strip() == "":
                raw_lines.append("")
                index += 1
                continue
            if self._indent(index) <= parent_indent:
                break
            raw_lines.append(line)
            index += 1

        non_empty_indents = [
            len(line) - len(line.lstrip(" "))
            for line in raw_lines
            if line.strip() != ""
        ]
        content_indent = min(non_empty_indents) if non_empty_indents else parent_indent + 2
        stripped = [
            line[content_indent:] if len(line) >= content_indent else ""
            for line in raw_lines
        ]

        if indicator.startswith(">"):
            text = self._fold_block(stripped)
        else:
            text = "\n".join(stripped)
            if stripped:
                text += "\n"

        chomp = indicator[1:] if len(indicator) > 1 else ""
        if "-" in chomp:
            text = text.rstrip("\n")
        elif "+" not in chomp and raw_lines:
            text = text.rstrip("\n") + "\n"

        return text, index

    def _fold_block(self, lines):
        paragraphs = []
        current = []
        for line in lines:
            if line == "":
                if current:
                    paragraphs.append(" ".join(current))
                    current = []
                paragraphs.append("")
            else:
                current.append(line)
        if current:
            paragraphs.append(" ".join(current))
        return "\n".join(paragraphs)

    def _split_key_value(self, content, index):
        in_quote = None
        for position, char in enumerate(content):
            if char in ("'", '"'):
                if in_quote == char:
                    in_quote = None
                elif in_quote is None:
                    in_quote = char
            if char == ":" and in_quote is None:
                return content[:position].strip(), content[position + 1 :].strip()
        self._error(index, "expected 'key: value'")

    def _looks_like_key_value(self, content):
        if ":" not in content:
            return False
        key, _, remainder = content.partition(":")
        return bool(key.strip()) and (not remainder or remainder.startswith(" "))

    def _parse_key(self, value):
        value = value.strip()
        if not value:
            raise BrunoYamlError(f"{self.path}: empty mapping key")
        return as_text(self._parse_scalar(value))

    def _parse_scalar(self, value):
        value = value.strip()
        if value == "":
            return ""
        if value in ("~", "null", "Null", "NULL"):
            return None
        if value in ("true", "True", "TRUE"):
            return True
        if value in ("false", "False", "FALSE"):
            return False
        if value[0] == value[-1:] == "'":
            return value[1:-1].replace("''", "'")
        if value[0] == value[-1:] == '"':
            try:
                return json.loads(value)
            except json.JSONDecodeError:
                return value[1:-1]
        if value.startswith("[") or value.startswith("{"):
            try:
                return json.loads(value)
            except json.JSONDecodeError:
                return value
        if re.fullmatch(r"[-+]?[0-9]+", value):
            try:
                return int(value)
            except ValueError:
                return value
        if re.fullmatch(r"[-+]?(?:[0-9]+\.[0-9]*|[0-9]*\.[0-9]+)(?:[eE][-+]?[0-9]+)?", value):
            try:
                return float(value)
            except ValueError:
                return value
        return value

    def _is_block_scalar(self, value):
        return re.fullmatch(r"[|>][+-]?", value) is not None

    def _skip_ignored(self, index):
        while index < len(self.lines):
            stripped = self.lines[index].strip()
            if stripped == "" or stripped.startswith("#"):
                index += 1
                continue
            break
        return index

    def _indent(self, index):
        line = self.lines[index]
        if "\t" in line[: len(line) - len(line.lstrip())]:
            self._error(index, "tabs are not supported for indentation")
        return len(line) - len(line.lstrip(" "))

    def _error(self, index, message):
        raise BrunoYamlError(f"{self.path}:{index + 1}: {message}")


def is_enabled(item):
    return not isinstance(item, dict) or item.get("enabled", True) is not False


def as_text(value):
    if value is None:
        return ""
    if value is True:
        return "true"
    if value is False:
        return "false"
    if isinstance(value, str):
        return value
    return str(value)


def load_yaml(path):
    with open(path, "r", encoding="utf-8") as handle:
        data = SimpleYamlParser(handle.read(), path).parse() or {}
    if not isinstance(data, dict):
        raise BrunoYamlError(f"{path} is not a Bruno YAML request")
    return data


def find_collection_root(target):
    target = os.path.abspath(target)
    search_dir = target if os.path.isdir(target) else os.path.dirname(target)

    current = search_dir
    while current != os.path.dirname(current):
        if os.path.exists(os.path.join(current, "bruno.json")) or os.path.exists(
            os.path.join(current, "opencollection.yml")
        ):
            return current
        current = os.path.dirname(current)

    raise BrunoYamlError(f"No Bruno collection root found for {target}")


def header_items(value):
    if not value:
        return []
    if isinstance(value, dict):
        return [(as_text(k), as_text(v)) for k, v in value.items()]
    if isinstance(value, list):
        items = []
        for item in value:
            if not is_enabled(item):
                continue
            if isinstance(item, dict):
                name = item.get("name") or item.get("key")
                if name:
                    items.append((as_text(name), as_text(item.get("value"))))
        return items
    return []


def named_values(value):
    if not value:
        return []
    if isinstance(value, dict):
        return [(as_text(k), as_text(v)) for k, v in value.items()]
    if isinstance(value, list):
        values = []
        for item in value:
            if not is_enabled(item):
                continue
            if isinstance(item, dict):
                name = item.get("name") or item.get("key")
                if name:
                    values.append((as_text(name), as_text(item.get("value"))))
        return values
    return []


def append_query(url, pairs):
    if not pairs:
        return url

    parts = urllib.parse.urlsplit(url)
    existing = urllib.parse.parse_qsl(parts.query, keep_blank_values=True)
    query = urllib.parse.urlencode(existing + pairs, doseq=True)
    return urllib.parse.urlunsplit((parts.scheme, parts.netloc, parts.path, query, parts.fragment))


def build_multipart(fields):
    boundary = "----bruno-zed-form-boundary"
    chunks = []
    for name, value in fields:
        chunks.append(f"--{boundary}\r\n")
        chunks.append(f'Content-Disposition: form-data; name="{name}"\r\n\r\n')
        chunks.append(value)
        chunks.append("\r\n")
    chunks.append(f"--{boundary}--\r\n")
    return "".join(chunks).encode("utf-8"), f"multipart/form-data; boundary={boundary}"


def build_body(body):
    if not isinstance(body, dict):
        return None, None

    body_type = as_text(body.get("type")).lower()
    data = body.get("data")

    if body_type in ("", "none", "no-body"):
        return None, None

    if body_type in ("form-urlencoded", "x-www-form-urlencoded"):
        return urllib.parse.urlencode(named_values(data), doseq=True).encode("utf-8"), "application/x-www-form-urlencoded"

    if body_type == "multipart":
        return build_multipart(named_values(data))

    if body_type == "json":
        if isinstance(data, str):
            return data.encode("utf-8"), "application/json"
        return json.dumps(data if data is not None else {}, ensure_ascii=False).encode("utf-8"), "application/json"

    if body_type in ("text", "xml", "html"):
        content_type = "text/plain"
        if body_type == "xml":
            content_type = "application/xml"
        elif body_type == "html":
            content_type = "text/html"
        return as_text(data).encode("utf-8"), content_type

    if data is None:
        return None, None
    return as_text(data).encode("utf-8"), None


def request_from_yaml(path):
    request = load_yaml(path)
    http = request.get("http")
    if not isinstance(http, dict):
        raise BrunoYamlError(f"{path} does not contain an http request")

    method = as_text(http.get("method") or "GET").upper()
    url = as_text(http.get("url"))
    if not url:
        raise BrunoYamlError(f"{path} does not contain http.url")

    headers = {}
    for name, value in header_items(request.get("headers")) + header_items(http.get("headers")):
        headers[name] = value

    query_pairs = []
    for candidate in (request.get("query"), http.get("query"), http.get("params")):
        if isinstance(candidate, dict) and "data" in candidate:
            query_pairs.extend(named_values(candidate.get("data")))
        else:
            query_pairs.extend(named_values(candidate))
    url = append_query(url, query_pairs)

    body_bytes, content_type = build_body(http.get("body"))
    if body_bytes is not None and content_type and not any(k.lower() == "content-type" for k in headers):
        headers["Content-Type"] = content_type

    settings = request.get("settings") if isinstance(request.get("settings"), dict) else {}
    timeout = settings.get("timeout", 0)
    timeout = None if not timeout else float(timeout) / 1000
    follow_redirects = settings.get("followRedirects", True) is not False

    return {
        "method": method,
        "url": url,
        "headers": headers,
        "body": body_bytes,
        "timeout": timeout,
        "follow_redirects": follow_redirects,
    }


def decode_response_body(body, content_type):
    if not body:
        return None

    charset = "utf-8"
    if "charset=" in content_type:
        charset = content_type.split("charset=", 1)[1].split(";", 1)[0].strip() or "utf-8"

    is_text = any(content_type.lower().startswith(prefix) for prefix in TEXT_CONTENT_TYPES)
    try:
        decoded = body.decode(charset, errors="replace")
    except LookupError:
        decoded = body.decode("utf-8", errors="replace")

    if "json" in content_type.lower():
        try:
            return json.dumps(json.loads(decoded), ensure_ascii=False, indent=2)
        except json.JSONDecodeError:
            return decoded

    if is_text or _looks_like_text(decoded):
        return decoded

    return f"<binary response: {len(body)} bytes>"


def _looks_like_text(value):
    if not value:
        return True
    sample = value[:512]
    return "\ufffd" not in sample and all(char == "\n" or char == "\r" or char == "\t" or ord(char) >= 32 for char in sample)


def print_response(status, reason, headers, body, elapsed):
    print(f"HTTP {status} {reason} ({elapsed * 1000:.0f} ms)")
    for name, value in headers.items():
        print(f"{name}: {value}")

    decoded = decode_response_body(body, headers.get("content-type", ""))
    if decoded:
        print()
        print(decoded)


def run_request(path, dry_run=False):
    spec = request_from_yaml(path)
    body_len = len(spec["body"] or b"")

    print(f"{spec['method']} {spec['url']}")
    if body_len:
        print(f"Request body: {body_len} bytes")

    if dry_run:
        return 0

    req = urllib.request.Request(
        spec["url"],
        data=spec["body"],
        headers=spec["headers"],
        method=spec["method"],
    )
    opener = urllib.request.build_opener() if spec["follow_redirects"] else urllib.request.build_opener(NoRedirectHandler)

    started_at = time.monotonic()
    try:
        response = opener.open(req, timeout=spec["timeout"])
        status = response.status
        reason = response.reason
        body = response.read()
        headers = response.headers
    except urllib.error.HTTPError as error:
        status = error.code
        reason = error.reason
        body = error.read()
        headers = error.headers
    except urllib.error.URLError as error:
        elapsed = time.monotonic() - started_at
        print(f"Request failed after {elapsed * 1000:.0f} ms: {error.reason}", file=sys.stderr)
        return 1
    except socket.timeout:
        elapsed = time.monotonic() - started_at
        print(f"Request timed out after {elapsed * 1000:.0f} ms", file=sys.stderr)
        return 1

    elapsed = time.monotonic() - started_at
    print_response(status, reason, headers, body, elapsed)
    return 0 if status < 400 else 1


def request_files(root):
    result = []
    for current, dirs, files in os.walk(root):
        dirs[:] = [d for d in dirs if d not in (".git", "node_modules")]
        for name in files:
            if name == "opencollection.yml":
                continue
            if name.endswith(REQUEST_EXTENSIONS):
                path = os.path.join(current, name)
                try:
                    data = load_yaml(path)
                except BrunoYamlError:
                    continue
                if isinstance(data.get("http"), dict):
                    result.append(path)
    return sorted(result)


def main():
    parser = argparse.ArgumentParser(description="Run Bruno YAML requests from Zed")
    parser.add_argument("--collection", action="store_true", help="Run all YAML requests in the collection")
    parser.add_argument("--dry-run", action="store_true", help="Print the request without sending it")
    parser.add_argument("target", nargs="?", default=os.environ.get("ZED_FILE"))
    args, extra_args = parser.parse_known_args()

    if extra_args:
        print(f"Ignoring unsupported Bruno CLI option(s) for YAML runner: {' '.join(extra_args)}", file=sys.stderr)

    if not args.target:
        print("usage: bru-zed-yaml-run <request.yml>", file=sys.stderr)
        return 64

    try:
        target = os.path.abspath(args.target)
        root = find_collection_root(target)

        if args.collection:
            files = request_files(root)
            if not files:
                print(f"No Bruno YAML requests found in {root}", file=sys.stderr)
                return 4
            exit_code = 0
            for index, path in enumerate(files):
                if index:
                    print()
                print(os.path.relpath(path, root))
                exit_code = max(exit_code, run_request(path, dry_run=args.dry_run))
            return exit_code

        return run_request(target, dry_run=args.dry_run)
    except BrunoYamlError as error:
        print(error, file=sys.stderr)
        return 65


if __name__ == "__main__":
    sys.exit(main())

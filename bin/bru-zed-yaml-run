#!/usr/bin/env python3
import argparse
import json
import os
import re
import socket
import sys
import time
import urllib.error
import urllib.parse
import urllib.request


REQUEST_EXTENSIONS = (".yml", ".yaml")
ENVIRONMENT_EXTENSIONS = (".yml", ".yaml", ".bru", ".json")
VARIABLE_PATTERN = re.compile(r"\{\{\s*([^{}]+?)\s*\}\}")
PROCESS_ENV_BRACKET_PATTERN = re.compile(r"""^process\.env\[['"](.+?)['"]\]$""")
TEXT_CONTENT_TYPES = (
    "application/json",
    "application/problem+json",
    "application/xml",
    "application/xhtml+xml",
    "application/javascript",
    "application/x-www-form-urlencoded",
    "text/",
)


class BrunoYamlError(ValueError):
    pass


class NoRedirectHandler(urllib.request.HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):
        return None


class SimpleYamlParser:
    """A small YAML subset parser for Bruno/OpenCollection request files."""

    def __init__(self, text, path="<string>"):
        self.lines = text.splitlines()
        self.path = path

    def parse(self):
        index = self._skip_ignored(0)
        if index >= len(self.lines):
            return {}
        value, index = self._parse_block(index, self._indent(index))
        index = self._skip_ignored(index)
        if index < len(self.lines):
            self._error(index, "unexpected trailing content")
        return value

    def _parse_block(self, index, indent):
        index = self._skip_ignored(index)
        if index >= len(self.lines):
            return None, index

        current_indent = self._indent(index)
        if current_indent < indent:
            return None, index

        content = self.lines[index][current_indent:]
        if content.startswith("-"):
            return self._parse_sequence(index, current_indent)
        return self._parse_mapping(index, current_indent)

    def _parse_mapping(self, index, indent):
        result = {}
        while index < len(self.lines):
            index = self._skip_ignored(index)
            if index >= len(self.lines):
                break

            current_indent = self._indent(index)
            if current_indent < indent:
                break
            if current_indent > indent:
                self._error(index, "unexpected indentation")

            content = self.lines[index][indent:]
            if content.startswith("-"):
                break

            key, value_text = self._split_key_value(content, index)
            key = self._parse_key(key)
            value, index = self._parse_value(value_text, index, indent)
            result[key] = value

        return result, index

    def _parse_sequence(self, index, indent):
        result = []
        while index < len(self.lines):
            index = self._skip_ignored(index)
            if index >= len(self.lines):
                break

            current_indent = self._indent(index)
            if current_indent < indent:
                break
            if current_indent > indent:
                self._error(index, "unexpected indentation")

            content = self.lines[index][indent:]
            if not content.startswith("-"):
                break

            item_text = content[1:]
            if item_text.startswith(" "):
                item_text = item_text[1:]
            elif item_text:
                self._error(index, "expected a space after '-'")

            if not item_text:
                next_index = self._skip_ignored(index + 1)
                if next_index < len(self.lines) and self._indent(next_index) > indent:
                    item, index = self._parse_block(next_index, self._indent(next_index))
                else:
                    item, index = None, index + 1
                result.append(item)
                continue

            if self._looks_like_key_value(item_text):
                key, value_text = self._split_key_value(item_text, index)
                item = {}
                value, index = self._parse_value(value_text, index, indent + 2)
                item[self._parse_key(key)] = value

                next_index = self._skip_ignored(index)
                if next_index < len(self.lines) and self._indent(next_index) > indent:
                    extra, index = self._parse_mapping(next_index, self._indent(next_index))
                    item.update(extra)
                result.append(item)
                continue

            result.append(self._parse_scalar(item_text))
            index += 1

        return result, index

    def _parse_value(self, value_text, index, indent):
        value_text = value_text.strip()

        if not value_text:
            next_index = self._skip_ignored(index + 1)
            if next_index < len(self.lines) and self._indent(next_index) > indent:
                return self._parse_block(next_index, self._indent(next_index))
            return None, index + 1

        if self._is_block_scalar(value_text):
            return self._parse_block_scalar(index + 1, indent, value_text)

        return self._parse_scalar(value_text), index + 1

    def _parse_block_scalar(self, index, parent_indent, indicator):
        raw_lines = []
        while index < len(self.lines):
            line = self.lines[index]
            if line.strip() == "":
                raw_lines.append("")
                index += 1
                continue
            if self._indent(index) <= parent_indent:
                break
            raw_lines.append(line)
            index += 1

        non_empty_indents = [
            len(line) - len(line.lstrip(" "))
            for line in raw_lines
            if line.strip() != ""
        ]
        content_indent = min(non_empty_indents) if non_empty_indents else parent_indent + 2
        stripped = [
            line[content_indent:] if len(line) >= content_indent else ""
            for line in raw_lines
        ]

        if indicator.startswith(">"):
            text = self._fold_block(stripped)
        else:
            text = "\n".join(stripped)
            if stripped:
                text += "\n"

        chomp = indicator[1:] if len(indicator) > 1 else ""
        if "-" in chomp:
            text = text.rstrip("\n")
        elif "+" not in chomp and raw_lines:
            text = text.rstrip("\n") + "\n"

        return text, index

    def _fold_block(self, lines):
        paragraphs = []
        current = []
        for line in lines:
            if line == "":
                if current:
                    paragraphs.append(" ".join(current))
                    current = []
                paragraphs.append("")
            else:
                current.append(line)
        if current:
            paragraphs.append(" ".join(current))
        return "\n".join(paragraphs)

    def _split_key_value(self, content, index):
        in_quote = None
        for position, char in enumerate(content):
            if char in ("'", '"'):
                if in_quote == char:
                    in_quote = None
                elif in_quote is None:
                    in_quote = char
            if char == ":" and in_quote is None:
                return content[:position].strip(), content[position + 1 :].strip()
        self._error(index, "expected 'key: value'")

    def _looks_like_key_value(self, content):
        if ":" not in content:
            return False
        key, _, remainder = content.partition(":")
        return bool(key.strip()) and (not remainder or remainder.startswith(" "))

    def _parse_key(self, value):
        value = value.strip()
        if not value:
            raise BrunoYamlError(f"{self.path}: empty mapping key")
        return as_text(self._parse_scalar(value))

    def _parse_scalar(self, value):
        value = value.strip()
        if value == "":
            return ""
        if value in ("~", "null", "Null", "NULL"):
            return None
        if value in ("true", "True", "TRUE"):
            return True
        if value in ("false", "False", "FALSE"):
            return False
        if value[0] == value[-1:] == "'":
            return value[1:-1].replace("''", "'")
        if value[0] == value[-1:] == '"':
            try:
                return json.loads(value)
            except json.JSONDecodeError:
                return value[1:-1]
        if value.startswith("[") or value.startswith("{"):
            try:
                return json.loads(value)
            except json.JSONDecodeError:
                return value
        if re.fullmatch(r"[-+]?[0-9]+", value):
            try:
                return int(value)
            except ValueError:
                return value
        if re.fullmatch(r"[-+]?(?:[0-9]+\.[0-9]*|[0-9]*\.[0-9]+)(?:[eE][-+]?[0-9]+)?", value):
            try:
                return float(value)
            except ValueError:
                return value
        return value

    def _is_block_scalar(self, value):
        return re.fullmatch(r"[|>][+-]?", value) is not None

    def _skip_ignored(self, index):
        while index < len(self.lines):
            stripped = self.lines[index].strip()
            if stripped == "" or stripped.startswith("#"):
                index += 1
                continue
            break
        return index

    def _indent(self, index):
        line = self.lines[index]
        if "\t" in line[: len(line) - len(line.lstrip())]:
            self._error(index, "tabs are not supported for indentation")
        return len(line) - len(line.lstrip(" "))

    def _error(self, index, message):
        raise BrunoYamlError(f"{self.path}:{index + 1}: {message}")


def is_enabled(item):
    return not isinstance(item, dict) or (
        item.get("enabled", True) is not False and item.get("disabled", False) is not True
    )


def as_text(value):
    if value is None:
        return ""
    if value is True:
        return "true"
    if value is False:
        return "false"
    if isinstance(value, str):
        return value
    return str(value)


def load_yaml(path):
    with open(path, "r", encoding="utf-8") as handle:
        data = SimpleYamlParser(handle.read(), path).parse() or {}
    if not isinstance(data, dict):
        raise BrunoYamlError(f"{path} is not a Bruno YAML request")
    return data


def load_json(path):
    with open(path, "r", encoding="utf-8") as handle:
        return json.load(handle)


def find_collection_root(target):
    target = os.path.abspath(target)
    search_dir = target if os.path.isdir(target) else os.path.dirname(target)

    current = search_dir
    while current != os.path.dirname(current):
        if os.path.exists(os.path.join(current, "bruno.json")) or os.path.exists(
            os.path.join(current, "opencollection.yml")
        ):
            return current
        current = os.path.dirname(current)

    raise BrunoYamlError(f"No Bruno collection root found for {target}")


def parse_dotenv(path):
    values = {}
    if not os.path.exists(path):
        return values

    with open(path, "r", encoding="utf-8") as handle:
        for raw_line in handle:
            line = raw_line.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith("export "):
                line = line[len("export ") :].strip()
            if "=" not in line:
                continue
            name, value = line.split("=", 1)
            name = name.strip()
            value = value.strip()
            if not name:
                continue
            if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
                value = value[1:-1]
            values[name] = value
    return values


def load_bru_vars(path):
    with open(path, "r", encoding="utf-8") as handle:
        text = handle.read()

    match = re.search(r"(^|\n)\s*vars(?::[A-Za-z_-]+)?\s*\{\s*(.*?)\n\s*\}", text, flags=re.DOTALL)
    if not match:
        return {}

    values = {}
    for raw_line in match.group(2).splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or line.startswith("//"):
            continue
        disabled = line.startswith("~")
        if disabled:
            line = line[1:].strip()
        if ":" not in line:
            continue
        name, value = line.split(":", 1)
        name = name.strip()
        value = value.strip()
        if name and not disabled:
            values[name] = value
    return values


def variable_to_text(value):
    if isinstance(value, (dict, list)):
        return json.dumps(value, ensure_ascii=False)
    return as_text(value)


def variable_items(value):
    if not value:
        return []
    if isinstance(value, dict):
        return [(as_text(name), variable_to_text(variable)) for name, variable in value.items()]
    if isinstance(value, list):
        items = []
        for item in value:
            if not is_enabled(item):
                continue
            if not isinstance(item, dict):
                continue
            name = item.get("name") or item.get("key")
            if not name:
                continue
            value = item.get("value")
            if isinstance(value, dict) and "data" in value:
                value = value.get("data")
            items.append((as_text(name), variable_to_text(value)))
        return items
    return []


def extract_variables(data):
    if not isinstance(data, dict):
        return {}

    values = {}
    for key in ("vars", "variables"):
        for name, value in variable_items(data.get(key)):
            values[name] = value

    runtime = data.get("runtime")
    if isinstance(runtime, dict):
        for name, value in variable_items(runtime.get("variables")):
            values[name] = value

    request = data.get("request")
    if isinstance(request, dict):
        for name, value in variable_items(request.get("variables")):
            values[name] = value

    return values


def load_variables_file(path):
    extension = os.path.splitext(path)[1].lower()
    if extension in (".yml", ".yaml"):
        return extract_variables(load_yaml(path))
    if extension == ".json":
        return extract_variables(load_json(path))
    if extension == ".bru":
        return load_bru_vars(path)
    return {}


def environment_file_for_name(root, env_name):
    if not env_name:
        return None

    env_dir = os.path.join(root, "environments")
    if not os.path.isdir(env_dir):
        return None

    normalized = env_name.lower()
    candidates = []
    for extension in ENVIRONMENT_EXTENSIONS:
        candidates.append(os.path.join(env_dir, f"{env_name}{extension}"))
        candidates.append(os.path.join(env_dir, f"{normalized}{extension}"))

    for candidate in candidates:
        if os.path.exists(candidate):
            return candidate

    for name in sorted(os.listdir(env_dir)):
        path = os.path.join(env_dir, name)
        if not os.path.isfile(path) or os.path.splitext(path)[1].lower() not in ENVIRONMENT_EXTENSIONS:
            continue
        if os.path.splitext(name)[0].lower() == normalized:
            return path
        try:
            extension = os.path.splitext(path)[1].lower()
            if extension in (".yml", ".yaml", ".json"):
                data = load_yaml(path) if extension in (".yml", ".yaml") else load_json(path)
                if as_text(data.get("name")).lower() == normalized:
                    return path
        except Exception:
            continue
    return None


def parse_env_var_overrides(values):
    result = {}
    for value in values or []:
        if "=" not in value:
            raise BrunoYamlError(f"--env-var expects KEY=VALUE, got {value}")
        name, override = value.split("=", 1)
        name = name.strip()
        if not name:
            raise BrunoYamlError("--env-var expects a non-empty variable name")
        result[name] = override
    return result


def load_variable_context(root, request, request_path, env_name=None, env_files=None, env_vars=None):
    variables = {}

    collection_path = os.path.join(root, "opencollection.yml")
    if os.path.exists(collection_path):
        variables.update(extract_variables(load_yaml(collection_path)))

    environment_path = environment_file_for_name(root, env_name)
    if env_name and not environment_path:
        raise BrunoYamlError(f"No Bruno environment named {env_name} found in {os.path.join(root, 'environments')}")
    if environment_path:
        variables.update(load_variables_file(environment_path))

    for env_file in env_files or []:
        path = env_file if os.path.isabs(env_file) else os.path.join(root, env_file)
        if not os.path.exists(path):
            raise BrunoYamlError(f"No Bruno environment file found at {path}")
        variables.update(load_variables_file(path))

    for folder_file in folder_variable_files(root, request_path):
        variables.update(load_variables_file(folder_file))

    variables.update(extract_variables(request))
    variables.update(parse_env_var_overrides(env_vars))

    process_env = dict(os.environ)
    process_env.update(parse_dotenv(os.path.join(root, ".env")))
    variables = resolve_variable_values(variables, process_env)
    return variables, process_env


def folder_variable_files(root, request_path):
    files = []
    current = os.path.dirname(os.path.abspath(request_path))
    root = os.path.abspath(root)
    while current == root or current.startswith(root + os.sep):
        for name in ("folder.yml", "folder.yaml", "folder.bru"):
            path = os.path.join(current, name)
            if os.path.exists(path):
                files.append(path)
        if current == root:
            break
        current = os.path.dirname(current)
    return list(reversed(files))


def resolve_variable_values(variables, process_env):
    resolved = dict(variables)
    for _ in range(8):
        changed = False
        for name, value in list(resolved.items()):
            next_value = interpolate_string(value, resolved, process_env, set())
            if next_value != value:
                resolved[name] = next_value
                changed = True
        if not changed:
            break
    return resolved


def interpolate(value, variables, process_env, unresolved):
    if isinstance(value, str):
        return interpolate_string(value, variables, process_env, unresolved)
    if isinstance(value, list):
        return [interpolate(item, variables, process_env, unresolved) for item in value]
    if isinstance(value, dict):
        return {
            interpolate(key, variables, process_env, unresolved): interpolate(item, variables, process_env, unresolved)
            for key, item in value.items()
        }
    return value


def interpolate_string(value, variables, process_env, unresolved):
    result = value
    for _ in range(8):
        def replacement(match):
            name = match.group(1).strip()
            if name.startswith("?"):
                return match.group(0)
            process_name = process_env_name(name)
            if process_name is not None:
                if process_name in process_env:
                    return process_env[process_name]
                unresolved.add(name)
                return match.group(0)
            if name in variables:
                return as_text(variables[name])
            unresolved.add(name)
            return match.group(0)

        next_result = VARIABLE_PATTERN.sub(replacement, result)
        if next_result == result:
            return result
        result = next_result
    return result


def process_env_name(name):
    if name.startswith("process.env."):
        return name[len("process.env.") :]
    match = PROCESS_ENV_BRACKET_PATTERN.match(name)
    if match:
        return match.group(1)
    return None


def header_items(value):
    if not value:
        return []
    if isinstance(value, dict):
        return [(as_text(k), as_text(v)) for k, v in value.items()]
    if isinstance(value, list):
        items = []
        for item in value:
            if not is_enabled(item):
                continue
            if isinstance(item, dict):
                name = item.get("name") or item.get("key")
                if name:
                    items.append((as_text(name), as_text(item.get("value"))))
        return items
    return []


def named_values(value):
    if not value:
        return []
    if isinstance(value, dict):
        return [(as_text(k), as_text(v)) for k, v in value.items()]
    if isinstance(value, list):
        values = []
        for item in value:
            if not is_enabled(item):
                continue
            if isinstance(item, dict):
                name = item.get("name") or item.get("key")
                if name:
                    values.append((as_text(name), as_text(item.get("value"))))
        return values
    return []


def query_param_values(value):
    if isinstance(value, dict) and "data" in value:
        return named_values(value.get("data"))
    if isinstance(value, list):
        values = []
        for item in value:
            if isinstance(item, dict) and as_text(item.get("type") or "query").lower() != "query":
                continue
            values.extend(named_values([item]))
        return values
    return named_values(value)


def append_query(url, pairs):
    if not pairs:
        return url

    parts = urllib.parse.urlsplit(url)
    existing = urllib.parse.parse_qsl(parts.query, keep_blank_values=True)
    query = urllib.parse.urlencode(existing + pairs, doseq=True)
    return urllib.parse.urlunsplit((parts.scheme, parts.netloc, parts.path, query, parts.fragment))


def build_multipart(fields):
    boundary = "----bruno-zed-form-boundary"
    chunks = []
    for name, value in fields:
        chunks.append(f"--{boundary}\r\n")
        chunks.append(f'Content-Disposition: form-data; name="{name}"\r\n\r\n')
        chunks.append(value)
        chunks.append("\r\n")
    chunks.append(f"--{boundary}--\r\n")
    return "".join(chunks).encode("utf-8"), f"multipart/form-data; boundary={boundary}"


def build_body(body):
    if not isinstance(body, dict):
        return None, None

    body_type = as_text(body.get("type")).lower()
    data = body.get("data")

    if body_type in ("", "none", "no-body"):
        return None, None

    if body_type in ("form-urlencoded", "x-www-form-urlencoded"):
        return urllib.parse.urlencode(named_values(data), doseq=True).encode("utf-8"), "application/x-www-form-urlencoded"

    if body_type == "multipart":
        return build_multipart(named_values(data))

    if body_type == "json":
        if isinstance(data, str):
            return data.encode("utf-8"), "application/json"
        return json.dumps(data if data is not None else {}, ensure_ascii=False).encode("utf-8"), "application/json"

    if body_type in ("text", "xml", "html"):
        content_type = "text/plain"
        if body_type == "xml":
            content_type = "application/xml"
        elif body_type == "html":
            content_type = "text/html"
        return as_text(data).encode("utf-8"), content_type

    if data is None:
        return None, None
    return as_text(data).encode("utf-8"), None


def request_from_yaml(path, root=None, env_name=None, env_files=None, env_vars=None):
    root = root or find_collection_root(path)
    request = load_yaml(path)
    variables, process_env = load_variable_context(
        root,
        request,
        path,
        env_name=env_name,
        env_files=env_files,
        env_vars=env_vars,
    )
    unresolved_variables = set()
    request = interpolate(request, variables, process_env, unresolved_variables)

    http = request.get("http")
    if not isinstance(http, dict):
        raise BrunoYamlError(f"{path} does not contain an http request")

    method = as_text(http.get("method") or "GET").upper()
    url = as_text(http.get("url"))
    if not url:
        raise BrunoYamlError(f"{path} does not contain http.url")

    headers = {}
    for name, value in header_items(request.get("headers")) + header_items(http.get("headers")):
        headers[name] = value

    query_pairs = []
    for candidate in (request.get("query"), http.get("query"), http.get("params")):
        query_pairs.extend(query_param_values(candidate))
    url = append_query(url, query_pairs)

    body_bytes, content_type = build_body(http.get("body"))
    if body_bytes is not None and content_type and not any(k.lower() == "content-type" for k in headers):
        headers["Content-Type"] = content_type

    settings = request.get("settings") if isinstance(request.get("settings"), dict) else {}
    timeout = settings.get("timeout", 0)
    timeout = None if not timeout else float(timeout) / 1000
    follow_redirects = settings.get("followRedirects", True) is not False

    return {
        "method": method,
        "url": url,
        "headers": headers,
        "body": body_bytes,
        "timeout": timeout,
        "follow_redirects": follow_redirects,
        "unresolved_variables": sorted(unresolved_variables),
    }


def decode_response_body(body, content_type):
    if not body:
        return None

    charset = "utf-8"
    if "charset=" in content_type:
        charset = content_type.split("charset=", 1)[1].split(";", 1)[0].strip() or "utf-8"

    is_text = any(content_type.lower().startswith(prefix) for prefix in TEXT_CONTENT_TYPES)
    try:
        decoded = body.decode(charset, errors="replace")
    except LookupError:
        decoded = body.decode("utf-8", errors="replace")

    if "json" in content_type.lower():
        try:
            return json.dumps(json.loads(decoded), ensure_ascii=False, indent=2)
        except json.JSONDecodeError:
            return decoded

    if is_text or _looks_like_text(decoded):
        return decoded

    return f"<binary response: {len(body)} bytes>"


def _looks_like_text(value):
    if not value:
        return True
    sample = value[:512]
    return "\ufffd" not in sample and all(char == "\n" or char == "\r" or char == "\t" or ord(char) >= 32 for char in sample)


def print_response(status, reason, headers, body, elapsed):
    print(f"HTTP {status} {reason} ({elapsed * 1000:.0f} ms)")
    for name, value in headers.items():
        print(f"{name}: {value}")

    decoded = decode_response_body(body, headers.get("content-type", ""))
    if decoded:
        print()
        print(decoded)


def run_request(path, root=None, env_name=None, env_files=None, env_vars=None, dry_run=False):
    spec = request_from_yaml(path, root=root, env_name=env_name, env_files=env_files, env_vars=env_vars)
    body_len = len(spec["body"] or b"")

    print(f"{spec['method']} {spec['url']}")
    if body_len:
        print(f"Request body: {body_len} bytes")
    if spec["unresolved_variables"]:
        print(f"Unresolved variables: {', '.join(spec['unresolved_variables'])}", file=sys.stderr)

    if dry_run:
        return 0

    req = urllib.request.Request(
        spec["url"],
        data=spec["body"],
        headers=spec["headers"],
        method=spec["method"],
    )
    opener = urllib.request.build_opener() if spec["follow_redirects"] else urllib.request.build_opener(NoRedirectHandler)

    started_at = time.monotonic()
    try:
        response = opener.open(req, timeout=spec["timeout"])
        status = response.status
        reason = response.reason
        body = response.read()
        headers = response.headers
    except urllib.error.HTTPError as error:
        status = error.code
        reason = error.reason
        body = error.read()
        headers = error.headers
    except urllib.error.URLError as error:
        elapsed = time.monotonic() - started_at
        print(f"Request failed after {elapsed * 1000:.0f} ms: {error.reason}", file=sys.stderr)
        return 1
    except socket.timeout:
        elapsed = time.monotonic() - started_at
        print(f"Request timed out after {elapsed * 1000:.0f} ms", file=sys.stderr)
        return 1

    elapsed = time.monotonic() - started_at
    print_response(status, reason, headers, body, elapsed)
    return 0 if status < 400 else 1


def request_files(root):
    result = []
    for current, dirs, files in os.walk(root):
        dirs[:] = [d for d in dirs if d not in (".git", "node_modules")]
        for name in files:
            if name == "opencollection.yml":
                continue
            if name.endswith(REQUEST_EXTENSIONS):
                path = os.path.join(current, name)
                try:
                    data = load_yaml(path)
                except BrunoYamlError:
                    continue
                if isinstance(data.get("http"), dict):
                    result.append(path)
    return sorted(result)


def default_env_files():
    value = os.environ.get("BRUNO_ENV_FILE", "")
    return [item for item in value.split(os.pathsep) if item]


def main():
    parser = argparse.ArgumentParser(description="Run Bruno YAML requests from Zed")
    parser.add_argument("--collection", action="store_true", help="Run all YAML requests in the collection")
    parser.add_argument("--dry-run", action="store_true", help="Print the request without sending it")
    parser.add_argument("--env", default=os.environ.get("BRUNO_ENV"), help="Load environments/<name>.yml, .yaml, .bru, or .json")
    parser.add_argument("--env-file", action="append", default=default_env_files(), help="Load a Bruno environment file")
    parser.add_argument("--env-var", action="append", default=[], help="Override a variable with KEY=VALUE")
    parser.add_argument("target", nargs="?", default=os.environ.get("ZED_FILE"))
    args, extra_args = parser.parse_known_args()

    if extra_args:
        print(f"Ignoring unsupported Bruno CLI option(s) for YAML runner: {' '.join(extra_args)}", file=sys.stderr)

    if not args.target:
        print("usage: bru-zed-yaml-run <request.yml>", file=sys.stderr)
        return 64

    try:
        target = os.path.abspath(args.target)
        root = find_collection_root(target)

        if args.collection:
            files = request_files(root)
            if not files:
                print(f"No Bruno YAML requests found in {root}", file=sys.stderr)
                return 4
            exit_code = 0
            for index, path in enumerate(files):
                if index:
                    print()
                print(os.path.relpath(path, root))
                exit_code = max(
                    exit_code,
                    run_request(
                        path,
                        root=root,
                        env_name=args.env,
                        env_files=args.env_file,
                        env_vars=args.env_var,
                        dry_run=args.dry_run,
                    ),
                )
            return exit_code

        return run_request(
            target,
            root=root,
            env_name=args.env,
            env_files=args.env_file,
            env_vars=args.env_var,
            dry_run=args.dry_run,
        )
    except BrunoYamlError as error:
        print(error, file=sys.stderr)
        return 65


if __name__ == "__main__":
    sys.exit(main())

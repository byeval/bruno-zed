#!/usr/bin/env sh
set -eu

target="${1:-${ZED_FILE:-}}"
collection_mode=false

if [ "${1:-}" = "--collection" ]; then
  collection_mode=true
  shift
  target="${1:-${ZED_FILE:-}}"
fi

if [ -z "$target" ]; then
  echo "usage: bru-zed-run <request-or-folder> [bru run options...]" >&2
  echo "or set ZED_FILE when running from a Zed task" >&2
  exit 64
fi

case "$target" in
  /*) target_abs="$target" ;;
  *) target_abs="$(pwd)/$target" ;;
esac

if [ -d "$target_abs" ]; then
  search_dir="$target_abs"
else
  search_dir="$(dirname "$target_abs")"
fi

collection_root="$search_dir"
while [ "$collection_root" != "/" ] &&
  [ ! -f "$collection_root/bruno.json" ] &&
  [ ! -f "$collection_root/opencollection.yml" ]; do
  collection_root="$(dirname "$collection_root")"
done

if [ ! -f "$collection_root/bruno.json" ] && [ ! -f "$collection_root/opencollection.yml" ]; then
  echo "No Bruno collection root found for $target_abs" >&2
  exit 4
fi

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

if [ "$collection_mode" = true ]; then
  shift || true
  if [ -f "$collection_root/bruno.json" ]; then
    cd "$collection_root"
    exec "${BRU:-bru}" run "$@"
  fi
  exec "$script_dir/bru-zed-yaml-run" --collection "$target_abs" "$@"
fi

case "$target_abs" in
  "$collection_root"/*) rel="${target_abs#"$collection_root/"}" ;;
  "$collection_root") rel="" ;;
  *) rel="$target_abs" ;;
esac

shift || true

case "$target_abs" in
  *.yml | *.yaml)
    exec "$script_dir/bru-zed-yaml-run" "$target_abs" "$@"
    ;;
esac

cd "$collection_root"

if [ ! -f "$collection_root/bruno.json" ]; then
  echo "Bruno CLI cannot run this collection because it has opencollection.yml but no bruno.json" >&2
  exit 4
fi

if [ -n "$rel" ]; then
  exec "${BRU:-bru}" run "$rel" "$@"
fi

exec "${BRU:-bru}" run "$@"

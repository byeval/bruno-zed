[
  {
    "label": "Bruno: Run current YAML request",
    "command": "runner=\"$HOME/Library/Application Support/Zed/extensions/installed/bruno/bin/bru-zed-run\"; \"$runner\" \"$ZED_FILE\"",
    "tags": ["bruno-yaml-request"],
    "reveal": "always",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "save": "current"
  },
  {
    "label": "Bruno: Run current collection",
    "command": "runner=\"$HOME/Library/Application Support/Zed/extensions/installed/bruno/bin/bru-zed-run\"; \"$runner\" --collection \"$ZED_FILE\"",
    "reveal": "always",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "save": "all"
  }
]
